<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_title"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/main_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textPermissionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/permission_section_title"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textPermissionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <Button
            android:id="@+id/buttonRequestOverlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/button_secondary"
            android:stateListAnimator="@null"
            android:text="@string/request_overlay_permission"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/buttonAddQuickSettingsTile"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_secondary"
            android:stateListAnimator="@null"
            android:text="@string/add_quick_settings_tile"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/buttonStartOverlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_primary"
            android:stateListAnimator="@null"
            android:text="@string/start_overlay"
            android:textAllCaps="false"
            android:textColor="@color/surface_dark"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonStopOverlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_danger"
            android:stateListAnimator="@null"
            android:text="@string/stop_overlay"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textStopNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/manual_stop_note"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
